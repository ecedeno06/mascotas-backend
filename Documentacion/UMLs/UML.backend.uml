@startuml

title IT Manager - Flujo General del Backend

actor Frontend

participant "server.js" as SERVER
participant "src/app.js" as APP
participant "Middlewares" as MIDDLEWARES
participant "Routes" as ROUTES
participant "Controllers" as CONTROLLERS
participant "JWT Service" as JWT
participant "Error Handler" as ERROR
database "PostgreSQL\nSupabase" as DB

== Inicio del Sistema ==

SERVER -> APP : Importar aplicación Express

APP -> MIDDLEWARES : Registrar middlewares
APP -> ROUTES : Registrar rutas
APP -> ERROR : Registrar middleware global

APP -> DB : Crear Pool PostgreSQL

SERVER -> SERVER : app.listen(PORT)

== Request HTTP ==

Frontend -> SERVER : HTTP Request

SERVER -> MIDDLEWARES : cors()
SERVER -> MIDDLEWARES : express.json()

MIDDLEWARES -> ROUTES : Buscar endpoint

ROUTES -> CONTROLLERS : Ejecutar controller

CONTROLLERS -> DB : pool.query()

DB --> CONTROLLERS : Resultado SQL

CONTROLLERS -> JWT : Generar token JWT

JWT --> CONTROLLERS : Token generado

CONTROLLERS --> Frontend : JSON Response

== Error Flow ==

CONTROLLERS -> ERROR : next(error)

ERROR --> Frontend : HTTP 500 JSON Error

@enduml